# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Database Wipe administrative authorization secret key (defaults to 'secret!' if not set)
DB_WIPE_SECRET_KEY="secret!"

# Secret key used for Remote Datawarehouse API headers (appended to X-API-Secret)
FOREX_API_SECRET="secret!"

# Endpoint URL for administrative analytics remote reporting service
ADMIN_API_URL="https://api.yourdomain.com/admin"

# Supabase database parameters (dynamic file-based setting removed)
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-anon-key-here"
SUPABASE_DB_URL="postgresql://postgres:password@db.your-project-id.supabase.co:5432/postgres?sslmode=require"

# CockroachDB primary database/cluster connection details
COCKROACH_DB_URL="postgresql://user:password@your-node.cockroachlabs.cloud:26257/defaultdb?sslmode=verify-full"

# CockroachDB multi-instance support (supported incrementally _1 to _10)
COCKROACH_DB_URL_1="postgresql://user:password@node-1.cockroachlabs.cloud:26257/defaultdb?sslmode=verify-full"
COCKROACH_DB_URL_2="postgresql://user:password@node-2.cockroachlabs.cloud:26257/defaultdb?sslmode=verify-full"
COCKROACH_DB_URL_3="postgresql://user:password@node-3.cockroachlabs.cloud:26257/defaultdb?sslmode=verify-full"
COCKROACH_DB_URL_4="postgresql://user:password@node-4.cockroachlabs.cloud:26257/defaultdb?sslmode=verify-full"
COCKROACH_DB_URL_5="postgresql://user:password@node-5.cockroachlabs.cloud:26257/defaultdb?sslmode=verify-full"
COCKROACH_DB_URL_6="postgresql://user:password@node-6.cockroachlabs.cloud:26257/defaultdb?sslmode=verify-full"
COCKROACH_DB_URL_7="postgresql://user:password@node-7.cockroachlabs.cloud:26257/defaultdb?sslmode=verify-full"
COCKROACH_DB_URL_8="postgresql://user:password@node-8.cockroachlabs.cloud:26257/defaultdb?sslmode=verify-full"
COCKROACH_DB_URL_9="postgresql://user:password@node-9.cockroachlabs.cloud:26257/defaultdb?sslmode=verify-full"
COCKROACH_DB_URL_10="postgresql://user:password@node-10.cockroachlabs.cloud:26257/defaultdb?sslmode=verify-full"
